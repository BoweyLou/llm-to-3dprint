{
  "schema_version": 1,
  "policy_id": "local-first-agent-permissions",
  "default_profile": "read-only-review",
  "profiles": [
    {
      "name": "read-only-review",
      "trust_level": "read-only-review",
      "purpose": "Inspect code, docs, diffs, and local command output without mutating repository or account state.",
      "filesystem": {
        "read": "allow",
        "write": "deny",
        "delete": "deny",
        "allowed_roots": ["."],
        "protected_paths": [".git", ".env", ".secrets", "node_modules"]
      },
      "shell": {
        "mode": "allowlisted",
        "allowlist": ["git status", "git diff", "rg", "sed", "python3 -m json.tool", "make workflow-help", "make agent-verify"],
        "denylist": ["rm", "git reset", "git checkout --", "git push", "git clean"]
      },
      "git": {
        "status": "allow",
        "diff": "allow",
        "stage": "deny",
        "commit": "deny",
        "push": "deny",
        "branch": "deny"
      },
      "browser": {
        "mode": "read-only",
        "allowed_domains": [],
        "account_mutation": "deny",
        "captcha_bypass": "deny"
      },
      "network": {
        "mode": "allowlisted",
        "allowed_hosts": []
      },
      "mcp": {
        "mode": "read-only",
        "allowed_servers": [],
        "write_tools": "deny"
      },
      "ci": {
        "run_checks": "allow",
        "comment_on_pr": "deny",
        "mutate_pr": "deny",
        "secrets_access": "deny"
      },
      "human_approval_required_for": [
        "file-write",
        "file-delete",
        "git-stage",
        "git-commit",
        "git-push",
        "pr-comment",
        "pr-mutation",
        "browser-account-mutation",
        "network-non-allowlisted",
        "mcp-write-tool",
        "ci-secret-access"
      ]
    },
    {
      "name": "untrusted-pr",
      "trust_level": "untrusted-pr",
      "purpose": "Review untrusted or fork-origin changes using safe JSON artifacts only.",
      "filesystem": {
        "read": "allow",
        "write": "approval-required",
        "delete": "deny",
        "allowed_roots": [".agent-workflows/runs"],
        "protected_paths": [".git", ".env", ".secrets", "src", "lib", "app", "docs"]
      },
      "shell": {
        "mode": "allowlisted",
        "allowlist": ["git status", "git diff", "rg", "python3 scripts/verify_agent_receipt.py"],
        "denylist": ["rm", "git reset", "git checkout --", "git push", "git clean", "curl", "wget"]
      },
      "git": {
        "status": "allow",
        "diff": "allow",
        "stage": "deny",
        "commit": "deny",
        "push": "deny",
        "branch": "deny"
      },
      "browser": {
        "mode": "none",
        "allowed_domains": [],
        "account_mutation": "deny",
        "captcha_bypass": "deny"
      },
      "network": {
        "mode": "none",
        "allowed_hosts": []
      },
      "mcp": {
        "mode": "read-only",
        "allowed_servers": [],
        "write_tools": "deny"
      },
      "ci": {
        "run_checks": "allow",
        "comment_on_pr": "deny",
        "mutate_pr": "deny",
        "secrets_access": "deny"
      },
      "human_approval_required_for": [
        "file-write",
        "file-delete",
        "git-stage",
        "git-commit",
        "git-push",
        "pr-comment",
        "pr-mutation",
        "browser-account-mutation",
        "network-non-allowlisted",
        "mcp-write-tool",
        "ci-secret-access"
      ]
    },
    {
      "name": "write-worker",
      "trust_level": "write-worker",
      "purpose": "Implement a scoped approved task in a local checkout or isolated worktree.",
      "filesystem": {
        "read": "allow",
        "write": "approval-required",
        "delete": "approval-required",
        "allowed_roots": ["."],
        "protected_paths": [".git", ".env", ".secrets"]
      },
      "shell": {
        "mode": "allowlisted",
        "allowlist": ["git status", "git diff", "rg", "python3", "make", "npm test"],
        "denylist": ["rm -rf", "git reset --hard", "git push --force"]
      },
      "git": {
        "status": "allow",
        "diff": "allow",
        "stage": "approval-required",
        "commit": "approval-required",
        "push": "approval-required",
        "branch": "approval-required"
      },
      "browser": {
        "mode": "none",
        "allowed_domains": [],
        "account_mutation": "deny",
        "captcha_bypass": "deny"
      },
      "network": {
        "mode": "allowlisted",
        "allowed_hosts": []
      },
      "mcp": {
        "mode": "read-only",
        "allowed_servers": [],
        "write_tools": "approval-required"
      },
      "ci": {
        "run_checks": "allow",
        "comment_on_pr": "approval-required",
        "mutate_pr": "approval-required",
        "secrets_access": "deny"
      },
      "human_approval_required_for": [
        "file-delete",
        "git-stage",
        "git-commit",
        "git-push",
        "pr-comment",
        "pr-mutation",
        "network-non-allowlisted",
        "mcp-write-tool",
        "ci-secret-access"
      ]
    },
    {
      "name": "browser-research",
      "trust_level": "browser-research",
      "purpose": "Collect source evidence through a browser session without changing account state.",
      "filesystem": {
        "read": "allow",
        "write": "approval-required",
        "delete": "deny",
        "allowed_roots": ["research", ".agent-workflows/runs"],
        "protected_paths": [".git", ".env", ".secrets"]
      },
      "shell": {
        "mode": "allowlisted",
        "allowlist": ["osascript", "python3 -m json.tool", "python3 scripts/agent_research.py", "rg"],
        "denylist": ["rm", "git reset", "git push"]
      },
      "git": {
        "status": "allow",
        "diff": "allow",
        "stage": "deny",
        "commit": "deny",
        "push": "deny",
        "branch": "deny"
      },
      "browser": {
        "mode": "read-only",
        "allowed_domains": [],
        "account_mutation": "deny",
        "captcha_bypass": "deny"
      },
      "network": {
        "mode": "allowlisted",
        "allowed_hosts": []
      },
      "mcp": {
        "mode": "read-only",
        "allowed_servers": [],
        "write_tools": "deny"
      },
      "ci": {
        "run_checks": "deny",
        "comment_on_pr": "deny",
        "mutate_pr": "deny",
        "secrets_access": "deny"
      },
      "human_approval_required_for": [
        "file-write",
        "file-delete",
        "git-stage",
        "git-commit",
        "git-push",
        "pr-comment",
        "pr-mutation",
        "browser-account-mutation",
        "network-non-allowlisted",
        "mcp-write-tool",
        "ci-secret-access"
      ]
    }
  ]
}
