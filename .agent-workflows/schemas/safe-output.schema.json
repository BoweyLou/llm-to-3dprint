{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-contract-kit/safe-output.schema.json",
  "title": "Doc Contract Safe Agent Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "status", "docs_impact", "findings", "proposed_actions"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "mode": {
      "type": "string",
      "enum": ["local-review", "docs-impact", "waiver-review", "test-first", "verification"]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "needs-human"]
    },
    "docs_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checked", "result"],
      "properties": {
        "checked": {
          "type": "boolean"
        },
        "result": {
          "type": "string",
          "enum": ["pass", "missing-docs", "waived", "not-applicable", "not-run"]
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "waiver_reason": {
          "type": ["string", "null"]
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "title", "evidence", "recommendation"],
        "properties": {
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "title": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "recommendation": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "proposed_actions": {
      "type": "array",
      "description": "Safe actions only. Direct writes, pushes, merges, deploys, comments, and account mutations are not allowed in this schema.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "target", "requires_human"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["update-docs", "add-waiver", "run-local-command", "open-human-task", "defer"]
          },
          "target": {
            "type": "string"
          },
          "requires_human": {
            "type": "boolean",
            "const": true
          }
        }
      }
    }
  }
}
