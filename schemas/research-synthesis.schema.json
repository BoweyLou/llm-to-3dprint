{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/research-synthesis.schema.json",
  "title": "Targeted Research Synthesis",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run", "summary", "source_reports", "proposals", "rejected_leads", "disposition"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research_id", "synthesized_at", "brief", "source_artifacts"],
      "properties": {
        "research_id": {
          "type": "string",
          "minLength": 1
        },
        "synthesized_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "brief": {
          "type": "string",
          "minLength": 1
        },
        "source_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "string"
      }
    },
    "source_reports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proposal"
      }
    },
    "source_plan_audit": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_plan_audit"
      }
    },
    "rejected_leads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rejected_lead"
      }
    },
    "disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "next_actions"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["complete", "pass-with-caveats", "blocked", "not-run"]
        },
        "summary": {
          "type": "string"
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "source_plan_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_report", "status", "notes"],
      "properties": {
        "source_report": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pass", "pass-with-caveats", "fail", "not-run"]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "priority", "title", "rationale", "source_evidence", "suggested_artifact", "docs_impact", "acceptance_criteria", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_-]*$"
        },
        "target": {
          "type": "string",
          "enum": ["backlog", "review", "architecture", "design", "adr", "risk", "task-packet"]
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "source_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "suggested_artifact": {
          "type": "string"
        },
        "docs_impact": {
          "type": "string",
          "enum": ["yes", "no", "unknown"]
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": ["draft", "needs-human-decision", "accepted", "rejected", "deferred"]
        }
      }
    },
    "rejected_lead": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "reason", "source_evidence"],
      "properties": {
        "title": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "source_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
