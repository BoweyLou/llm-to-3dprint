{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-contract-kit/agent-permission-policy.schema.json",
  "title": "Agent Permission Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "default_profile", "profiles"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "default_profile": {
      "type": "string",
      "minLength": 1
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "decision": {
      "type": "string",
      "enum": ["allow", "deny", "approval-required"]
    },
    "mode": {
      "type": "string",
      "enum": ["none", "read-only", "allowlisted", "unrestricted"]
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "trust_level",
        "purpose",
        "filesystem",
        "shell",
        "git",
        "browser",
        "network",
        "mcp",
        "ci",
        "human_approval_required_for"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "trust_level": {
          "type": "string",
          "enum": ["read-only-review", "untrusted-pr", "browser-research", "write-worker", "trusted-local"]
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "filesystem": {
          "$ref": "#/$defs/filesystem_policy"
        },
        "shell": {
          "$ref": "#/$defs/shell_policy"
        },
        "git": {
          "$ref": "#/$defs/git_policy"
        },
        "browser": {
          "$ref": "#/$defs/browser_policy"
        },
        "network": {
          "$ref": "#/$defs/network_policy"
        },
        "mcp": {
          "$ref": "#/$defs/mcp_policy"
        },
        "ci": {
          "$ref": "#/$defs/ci_policy"
        },
        "human_approval_required_for": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "file-write",
              "file-delete",
              "git-stage",
              "git-commit",
              "git-push",
              "pr-comment",
              "pr-mutation",
              "browser-account-mutation",
              "network-non-allowlisted",
              "mcp-write-tool",
              "ci-secret-access"
            ]
          }
        }
      }
    },
    "filesystem_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read", "write", "delete", "allowed_roots", "protected_paths"],
      "properties": {
        "read": {
          "$ref": "#/$defs/decision"
        },
        "write": {
          "$ref": "#/$defs/decision"
        },
        "delete": {
          "$ref": "#/$defs/decision"
        },
        "allowed_roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "protected_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "shell_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowlist", "denylist"],
      "properties": {
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "denylist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "git_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "diff", "stage", "commit", "push", "branch"],
      "properties": {
        "status": {
          "$ref": "#/$defs/decision"
        },
        "diff": {
          "$ref": "#/$defs/decision"
        },
        "stage": {
          "$ref": "#/$defs/decision"
        },
        "commit": {
          "$ref": "#/$defs/decision"
        },
        "push": {
          "$ref": "#/$defs/decision"
        },
        "branch": {
          "$ref": "#/$defs/decision"
        }
      }
    },
    "browser_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowed_domains", "account_mutation", "captcha_bypass"],
      "properties": {
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "allowed_domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "account_mutation": {
          "$ref": "#/$defs/decision"
        },
        "captcha_bypass": {
          "$ref": "#/$defs/decision"
        }
      }
    },
    "network_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowed_hosts"],
      "properties": {
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "allowed_hosts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "mcp_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowed_servers", "write_tools"],
      "properties": {
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "allowed_servers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write_tools": {
          "$ref": "#/$defs/decision"
        }
      }
    },
    "ci_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_checks", "comment_on_pr", "mutate_pr", "secrets_access"],
      "properties": {
        "run_checks": {
          "$ref": "#/$defs/decision"
        },
        "comment_on_pr": {
          "$ref": "#/$defs/decision"
        },
        "mutate_pr": {
          "$ref": "#/$defs/decision"
        },
        "secrets_access": {
          "$ref": "#/$defs/decision"
        }
      }
    }
  }
}
