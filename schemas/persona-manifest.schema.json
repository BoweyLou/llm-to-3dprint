{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/persona-manifest.schema.json",
  "title": "Agent Review Persona Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "local_first", "personas"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "local_first": {
      "type": "boolean",
      "const": true
    },
    "tool_agnostic": {
      "type": "boolean",
      "const": true
    },
    "review_policies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_trust_profile", "mutation_default", "policy_documents"],
      "properties": {
        "default_trust_profile": {
          "type": "string"
        },
        "mutation_default": {
          "type": "string",
          "enum": ["deny", "approval-required"]
        },
        "policy_documents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "personas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "prompt",
          "mode",
          "allowed_actions",
          "max_findings",
          "required_evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "prompt": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": ["read-only-review", "comment-only", "implementation", "verification"]
          },
          "risk_focus": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_actions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["read", "search", "run-local-checks", "write-comments", "edit-files"]
            }
          },
          "max_findings": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["file-path", "line-or-symbol", "command-or-static-check", "docs-or-adr", "runtime-surface"]
            }
          },
          "output_schema": {
            "type": "string"
          }
        }
      }
    }
  }
}
