{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/review-risk.schema.json",
  "title": "Review Risk Classification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "changed_files", "risk_tier", "trust_profile", "recommended_personas", "triggers", "guidance"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_tier": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "trust_profile": {
      "type": "string"
    },
    "recommended_personas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "rule_id", "tier", "reason", "personas"],
        "properties": {
          "path": {
            "type": "string"
          },
          "rule_id": {
            "type": "string"
          },
          "tier": {
            "type": "string",
            "enum": ["medium", "high", "critical"]
          },
          "reason": {
            "type": "string"
          },
          "personas": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "guidance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
