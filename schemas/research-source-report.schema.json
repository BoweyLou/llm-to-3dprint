{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/research-source-report.schema.json",
  "title": "Targeted Research Source Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run", "source", "queries", "sources_visited", "findings", "caveats", "disposition"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research_id", "agent_id", "started_at", "completed_at"],
      "properties": {
        "research_id": {
          "type": "string",
          "minLength": 1
        },
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "scope", "search_plan_followed"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["github", "arxiv", "hacker-news", "official-docs", "standards", "vendor-docs", "forums-social", "local-repo", "other"]
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "authenticated": {
          "type": "boolean",
          "default": false
        },
        "search_plan_followed": {
          "type": "boolean"
        },
        "deviations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources_visited": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_record"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "follow_up_needed"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["complete", "partial", "blocked", "not-run"]
        },
        "summary": {
          "type": "string"
        },
        "follow_up_needed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "source_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "retrieved_at", "source_quality"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "publisher": {
          "type": ["string", "null"]
        },
        "author": {
          "type": ["string", "null"]
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_quality": {
          "type": "string",
          "enum": ["primary", "secondary", "paper", "vendor", "anecdotal", "social", "unknown"]
        },
        "time_sensitive": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "claim", "evidence_grade", "source_urls", "relevance", "patterns", "risks", "recommended_follow_up"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "evidence_grade": {
          "type": "string",
          "enum": ["high", "medium", "low", "lead"]
        },
        "source_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "relevance": {
          "type": "string"
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_follow_up": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
