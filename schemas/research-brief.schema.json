{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/research-brief.schema.json",
  "title": "Targeted Research Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "research", "sources", "boundaries", "outputs", "approval"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "research": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "question", "repo_context"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "repo_context": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "requested_by": {
          "type": ["string", "null"]
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_type",
          "purpose",
          "query",
          "scope",
          "search_queries",
          "required_artifact_types",
          "min_results",
          "max_results",
          "quality_floor"
        ],
        "properties": {
        "source_type": {
            "type": "string",
            "enum": ["github", "arxiv", "hacker-news", "official-docs", "standards", "vendor-docs", "forums-social", "local-repo", "other"]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "allowed_domains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "seed_urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "search_queries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "include_terms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exclude_terms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_artifact_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["repo", "code", "docs", "issue", "pull-request", "discussion", "release", "paper", "standard", "api-reference", "thread", "comment", "local-file", "other"]
            }
          },
          "min_results": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "max_results": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "quality_floor": {
            "type": "string",
            "enum": ["high", "medium", "low", "lead"]
          },
          "freshness": {
            "type": ["string", "null"]
          },
          "allow_general_web": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trust_profile", "read_only", "forbidden_actions", "source_quality_rules"],
      "properties": {
        "trust_profile": {
          "type": "string",
          "default": "browser-research"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "forbidden_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_quality_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "artifact_dir", "success_criteria"],
      "properties": {
        "target": {
          "type": "string",
          "enum": ["backlog", "review", "architecture", "design", "adr", "risk", "task-packet"]
        },
        "artifact_dir": {
          "type": "string",
          "minLength": 1
        },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["human_approval_required", "proposed_writes_only"],
      "properties": {
        "human_approval_required": {
          "type": "boolean",
          "const": true
        },
        "proposed_writes_only": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
