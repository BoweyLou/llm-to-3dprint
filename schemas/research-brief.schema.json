{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/research-brief.schema.json",
  "title": "Targeted Research Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "research", "sources", "novelty_ledger", "boundaries", "outputs", "approval"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "research": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "question", "repo_context"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "repo_context": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "requested_by": {
          "type": ["string", "null"]
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_type",
          "purpose",
          "query",
          "scope",
          "search_queries",
          "required_artifact_types",
          "min_results",
          "max_results",
          "quality_floor"
        ],
        "properties": {
        "source_type": {
            "type": "string",
            "enum": ["github", "arxiv", "hacker-news", "official-docs", "standards", "vendor-docs", "forums-social", "local-repo", "other"]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "allowed_domains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "seed_urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "search_queries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "include_terms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exclude_terms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_artifact_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["repo", "code", "docs", "issue", "pull-request", "discussion", "release", "paper", "standard", "api-reference", "thread", "comment", "local-file", "other"]
            }
          },
          "min_results": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "max_results": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "quality_floor": {
            "type": "string",
            "enum": ["high", "medium", "low", "lead"]
          },
          "freshness": {
            "type": ["string", "null"]
          },
          "allow_general_web": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "novelty_ledger": {
      "$ref": "#/$defs/novelty_ledger"
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trust_profile", "read_only", "forbidden_actions", "source_quality_rules"],
      "properties": {
        "trust_profile": {
          "type": "string",
          "default": "browser-research"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "forbidden_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_quality_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "artifact_dir", "success_criteria"],
      "properties": {
        "target": {
          "type": "string",
          "enum": ["backlog", "review", "architecture", "design", "adr", "risk", "task-packet"]
        },
        "artifact_dir": {
          "type": "string",
          "minLength": 1
        },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["human_approval_required", "proposed_writes_only"],
      "properties": {
        "human_approval_required": {
          "type": "boolean",
          "const": true
        },
        "proposed_writes_only": {
          "type": "boolean",
          "const": true
        }
      }
    }
  },
  "$defs": {
    "novelty_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prior_question_fingerprints",
        "recent_topics",
        "novelty_threshold",
        "carry_forward_leads"
      ],
      "properties": {
        "prior_question_fingerprints": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recent_topics": {
          "type": "array",
          "maxItems": 25,
          "items": {
            "$ref": "#/$defs/recent_topic"
          }
        },
        "novelty_threshold": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 70
        },
        "carry_forward_leads": {
          "type": "array",
          "maxItems": 25,
          "items": {
            "$ref": "#/$defs/carry_forward_lead"
          }
        }
      }
    },
    "recent_topic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic", "summary", "last_seen_at", "fingerprints"],
      "properties": {
        "topic": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "last_seen_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "fingerprints": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "related_backlog_ids": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "carry_forward_lead": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "state", "reason", "source_evidence", "next_run_action"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "enum": ["rejected", "deferred"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "source_evidence": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string"
          }
        },
        "next_run_action": {
          "type": "string",
          "enum": ["do-not-repeat", "recheck-with-new-evidence", "reframe", "needs-human-decision"]
        },
        "fingerprint": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
