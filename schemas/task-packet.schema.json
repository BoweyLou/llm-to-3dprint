{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/task-packet.schema.json",
  "title": "Agent Task Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task",
    "context",
    "scope",
    "acceptance_criteria",
    "validation",
    "docs_impact",
    "risk",
    "approval"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "priority", "status", "source"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "status": {
          "type": "string",
          "enum": ["draft", "approved", "in-progress", "blocked", "done", "deferred"]
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["backlog", "issue", "review-finding", "decision", "human-request"]
            },
            "reference": {
              "type": ["string", "null"],
              "description": "Backlog id, issue id, finding id, note path, URL, or direct user request reference."
            }
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_root", "mode", "problem_statement"],
      "properties": {
        "repo_root": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "bootstrap",
            "drift",
            "pull-request",
            "release-gate",
            "learning-comments",
            "test-first",
            "verification"
          ]
        },
        "problem_statement": {
          "type": "string",
          "minLength": 1
        },
        "background": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_files", "protected_files"],
      "properties": {
        "allowed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "protected_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inspect_first": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "verification"],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "verification": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "required"],
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "required": {
                "type": "boolean"
              },
              "expected_result": {
                "type": "string"
              },
              "skip_policy": {
                "type": "string"
              }
            }
          }
        },
        "evidence_to_capture": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "docs_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected", "paths"],
      "properties": {
        "expected": {
          "type": "string",
          "enum": ["yes", "no", "unknown"]
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "waiver_allowed": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "known_risks", "stop_conditions"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "known_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["human_approval_required", "state"],
      "properties": {
        "human_approval_required": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": ["not-requested", "requested", "approved", "rejected"]
        },
        "approver": {
          "type": ["string", "null"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recommended_prompt": {
          "type": "string"
        },
        "owner": {
          "type": ["string", "null"]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_packet_hint": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
