{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/task-packet.schema.json",
  "title": "Agent Task Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task",
    "context",
    "story",
    "previous_task_state",
    "closeout_required_before_start",
    "goal_alignment",
    "scope",
    "acceptance_criteria",
    "validation",
    "closeout_requirements",
    "docs_impact",
    "risk",
    "approval"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "priority", "status", "source"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "status": {
          "type": "string",
          "enum": ["draft", "approved", "in-progress", "blocked", "done", "deferred"]
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["backlog", "issue", "review-finding", "decision", "human-request"]
            },
            "reference": {
              "type": ["string", "null"],
              "description": "Backlog id, issue id, finding id, note path, URL, or direct user request reference."
            }
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_root", "mode", "problem_statement", "non_goals"],
      "properties": {
        "repo_root": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "bootstrap",
            "drift",
            "pull-request",
            "release-gate",
            "learning-comments",
            "test-first",
            "verification"
          ]
        },
        "problem_statement": {
          "type": "string",
          "minLength": 1
        },
        "background": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "actor", "need", "outcome", "acceptance_summary"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user-story", "operator-story", "job-to-be-done"]
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "need": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_summary": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string"
        }
      }
    },
    "previous_task_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_sources",
        "active_tasks",
        "unresolved_blockers",
        "dirty_or_stale_state",
        "finalizer_receipt_paths",
        "blocker_receipt_paths",
        "allowed_to_start"
      ],
      "properties": {
        "report_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Deterministic reports, receipts, or scoped source checks consulted before deciding whether this task may start."
        },
        "active_tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          },
          "description": "Known active prior or sibling tasks from task-status, ledger, preflight, or equivalent reports."
        },
        "unresolved_blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Previous-task blockers that still need finalizer, self-heal, closeout, owner, or lifecycle action."
        },
        "dirty_or_stale_state": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Dirty checkout, stale metadata, missing worktree, missing receipt, or ambiguous prior-task state."
        },
        "finalizer_receipt_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Finalizer or final receipt paths proving prior work is closed before this task starts."
        },
        "blocker_receipt_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Blocker, self-heal, preflight, or owner-escalation receipt paths proving unsafe starts were refused."
        },
        "allowed_to_start": {
          "type": "boolean",
          "description": "True only when previous task state is resolved enough for the next implementation agent to edit."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "closeout_required_before_start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "reason", "required_next_step"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["safe-start", "refuse-start", "blocker-escalation"],
          "description": "Safe-start permits implementation; refuse-start stops before edits; blocker-escalation records unresolved prior state that needs owner or lifecycle action."
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "required_next_step": {
          "type": "string",
          "minLength": 1,
          "description": "Exact command, receipt, finalizer, closeout, self-heal, or owner action needed next."
        },
        "evidence_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "goal_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_goal",
        "area_contracts",
        "alignment_decision",
        "adaptation_needed",
        "stop_conditions"
      ],
      "properties": {
        "repo_goal": {
          "type": "string",
          "minLength": 1,
          "description": "Concise repository goal summary, source reference, or explicit unknown state."
        },
        "area_contracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "purpose", "status"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "purpose": {
                "type": "string",
                "minLength": 1,
                "description": "Affected area purpose summary, or an explicit unknown state."
              },
              "source": {
                "type": "string",
                "description": "Doc, ADR, packet, manual note, generated report, or unknown."
              },
              "status": {
                "type": "string",
                "enum": ["aligned", "unknown", "conflict", "not-applicable"]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "alignment_decision": {
          "type": "string",
          "enum": ["aligned", "unknown", "conflict", "adaptation-needed"],
          "description": "Unknown, conflict, or adaptation-needed decisions are stop or escalation states before implementation handoff."
        },
        "adaptation_needed": {
          "type": "boolean"
        },
        "stop_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Goal-alignment conditions that require human input, scope change, or a blocked handoff before implementation."
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_files", "protected_files"],
      "properties": {
        "allowed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "protected_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inspect_first": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "verification"],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "verification": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "required"],
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "required": {
                "type": "boolean"
              },
              "expected_result": {
                "type": "string"
              },
              "skip_policy": {
                "type": "string"
              }
            }
          }
        },
        "evidence_to_capture": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "closeout_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_receipt_path",
        "readiness_check",
        "lifecycle_action",
        "final_task_status",
        "closeout_preview",
        "dirty_state_explanation"
      ],
      "properties": {
        "final_receipt_path": {
          "type": "string",
          "minLength": 1,
          "description": "Expected durable final receipt path to link before task handoff."
        },
        "readiness_check": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command", "expected_result"],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            },
            "expected_result": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "lifecycle_action": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action", "command", "expected_result"],
          "properties": {
            "action": {
              "type": "string",
              "enum": ["finish", "block", "abandon"]
            },
            "command": {
              "type": "string",
              "minLength": 1
            },
            "expected_result": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "final_task_status": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command", "expected_result"],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            },
            "expected_result": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "closeout_preview": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command", "expected_result", "apply_requires_explicit_approval"],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            },
            "expected_result": {
              "type": "string",
              "minLength": 1
            },
            "apply_requires_explicit_approval": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "dirty_state_explanation": {
          "type": "string",
          "minLength": 1,
          "description": "Explicit explanation of any remaining dirty files, blocked cleanup, or confirmation that only expected task artifacts remain."
        }
      }
    },
    "docs_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected",
        "paths",
        "documentation_surfaces",
        "release_metadata",
        "generated_docs",
        "contract_references",
        "verification_commands"
      ],
      "properties": {
        "expected": {
          "type": "string",
          "enum": ["yes", "no", "unknown"]
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "documentation_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Exact docs, examples, README, ADR, runbook, or prompt docs expected to change or be checked."
        },
        "release_metadata": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Exact version, changelog, release-note, or No docs needed waiver surfaces to check."
        },
        "generated_docs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Generated docs or references that must be regenerated or checked for freshness."
        },
        "contract_references": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "JSON schemas, API docs, config references, OpenAPI claims, or docs-as-tests claim files relevant to the task."
        },
        "verification_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Docs, freshness, versioning, changelog, or docs-as-tests commands the implementer should run or explicitly skip."
        },
        "waiver_allowed": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "known_risks", "stop_conditions"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "known_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["human_approval_required", "state"],
      "properties": {
        "human_approval_required": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": ["not-requested", "requested", "approved", "rejected"]
        },
        "approver": {
          "type": ["string", "null"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "coordination": {
      "type": "object",
      "additionalProperties": true,
      "required": ["active_task_count", "active_tasks", "overlap_warnings"],
      "properties": {
        "active_task_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "overlap_warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "harness_metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "context_file_count": {
          "type": "integer",
          "minimum": 0
        },
        "token_budget": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recommended_prompt": {
          "type": "string"
        },
        "owner": {
          "type": ["string", "null"]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_packet_hint": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
