{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/review-synthesis.schema.json",
  "title": "Agent Review Synthesis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run",
    "summary",
    "findings",
    "remediation_batches",
    "needs_human_decision",
    "not_recommended",
    "disposition"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "mode", "synthesized_at", "source_artifacts"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["bootstrap", "drift", "pull-request", "release-gate"]
        },
        "synthesized_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/synthesis_finding"
      }
    },
    "remediation_batches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/remediation_batch"
      }
    },
    "needs_human_decision": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/human_decision"
      }
    },
    "not_recommended": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/not_recommended"
      }
    },
    "disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall_status", "summary", "next_actions"],
      "properties": {
        "overall_status": {
          "type": "string",
          "enum": ["pass", "pass-with-caveats", "fail", "blocked", "not-run"]
        },
        "summary": {
          "type": "string"
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "synthesis_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "priority",
        "severity",
        "area",
        "title",
        "confidence",
        "source_personas",
        "evidence",
        "impact",
        "recommendation",
        "verification",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_-]*$"
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "severity": {
          "type": "string",
          "enum": ["blocker", "high", "medium", "low"]
        },
        "area": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "source_personas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "file": {
          "type": ["string", "null"]
        },
        "line": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "impact": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "verification": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["open", "accepted", "rejected", "fixed", "deferred", "duplicate"]
        },
        "false_positive_notes": {
          "type": "string"
        },
        "related_finding_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "remediation_batch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "objective",
        "files_likely_touched",
        "findings_addressed",
        "suggested_owner",
        "verification",
        "risk_if_deferred"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_-]*$"
        },
        "objective": {
          "type": "string"
        },
        "files_likely_touched": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "findings_addressed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggested_owner": {
          "type": "string"
        },
        "verification": {
          "type": "string"
        },
        "risk_if_deferred": {
          "type": "string"
        }
      }
    },
    "human_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "reason", "options"],
      "properties": {
        "question": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "not_recommended": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "reason"],
      "properties": {
        "title": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "source_personas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
