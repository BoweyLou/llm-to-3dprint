{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-contract-kit/area-contracts.schema.json",
  "title": "Area Contracts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repo_goal", "path_contracts"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "repo_goal": {
      "type": "string",
      "minLength": 1
    },
    "unknown_policy": {
      "type": "string",
      "enum": ["warn", "block"]
    },
    "path_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose", "status"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Repo-relative file, directory prefix, or glob pattern."
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["aligned", "extends", "conflict", "unknown"]
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
