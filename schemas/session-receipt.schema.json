{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/session-receipt.schema.json",
  "title": "Local Agent Session Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run",
    "tooling",
    "scope",
    "evidence",
    "findings",
    "disposition"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "started_at", "mode"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "mode": {
          "type": "string",
          "enum": [
            "bootstrap",
            "drift",
            "pull-request",
            "release-gate",
            "learning-comments",
            "test-first",
            "verification"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["pass", "pass-with-caveats", "fail", "blocked", "not-run"]
        }
      }
    },
    "tooling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_tool", "local_only"],
      "properties": {
        "agent_tool": {
          "type": "string",
          "description": "The local coding tool that ran the workflow, for example codex, ampcode, claude-code, aider, or manual."
        },
        "agent_tool_version": {
          "type": ["string", "null"]
        },
        "local_only": {
          "type": "boolean",
          "description": "Must be true when the run was completed without GitHub Actions or hosted CI."
        },
        "network_used": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_root", "changed_files"],
      "properties": {
        "repo_root": {
          "type": "string"
        },
        "base_ref": {
          "type": ["string", "null"]
        },
        "behavior_change": {
          "type": ["boolean", "null"]
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "protected_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "review_risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_tier", "trust_profile", "triggers"],
      "properties": {
        "risk_tier": {
          "type": ["string", "null"],
          "enum": ["low", "medium", "high", "critical", null]
        },
        "trust_profile": {
          "type": ["string", "null"]
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "network_or_tool_allowlist_checked": {
          "type": "boolean"
        },
        "mutation_boundary_checked": {
          "type": "boolean"
        },
        "data_boundary_checked": {
          "type": "boolean"
        },
        "approved_deviations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "coordination": {
      "type": "object",
      "additionalProperties": true,
      "required": ["active_task_count", "active_tasks", "overlap_warnings"],
      "properties": {
        "active_task_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "overlap_warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "owner": {
          "type": ["string", "null"]
        },
        "session_id": {
          "type": ["string", "null"]
        },
        "heartbeat_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "lease_expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "harness_metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "context_file_count": {
          "type": "integer",
          "minimum": 0
        },
        "commands_run_count": {
          "type": "integer",
          "minimum": 0
        },
        "changed_file_count": {
          "type": "integer",
          "minimum": 0
        },
        "token_budget": {
          "type": "object",
          "additionalProperties": true
        },
        "review_outcome": {
          "$ref": "#/$defs/review_outcome_metrics"
        },
        "effort": {
          "$ref": "#/$defs/effort_metrics"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "docs_impact", "tests"],
      "properties": {
        "files_inspected": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_result"
          }
        },
        "docs_impact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["checked", "result"],
          "properties": {
            "checked": {
              "type": "boolean"
            },
            "result": {
              "type": "string",
              "enum": ["pass", "fail", "waived", "not-applicable", "not-run"]
            },
            "categories": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "waiver_reason": {
              "type": ["string", "null"]
            }
          }
        },
        "tests": {
          "type": "object",
          "additionalProperties": false,
          "required": ["result"],
          "properties": {
            "result": {
              "type": "string",
              "enum": ["red-green", "green-only", "not-applicable", "not-run", "blocked"]
            },
            "failing_test_evidence": {
              "type": ["string", "null"]
            },
            "passing_test_evidence": {
              "type": ["string", "null"]
            },
            "generated_test_provenance": {
              "type": ["string", "null"]
            },
            "skip_reason": {
              "type": ["string", "null"]
            }
          }
        },
        "comment_only_verification": {
          "type": "object",
          "description": "Machine-readable proof for learning-comments runs that changed files are comments only, explanation-note only, or an explicitly documented mix with no behavior change.",
          "additionalProperties": false,
          "required": [
            "checked",
            "result",
            "diff_scope",
            "behavior_change_assertion",
            "changed_files_reviewed",
            "comment_only_paths",
            "explanation_note_paths",
            "non_comment_paths",
            "non_comment_path_explanations",
            "source_files_changed",
            "evidence_commands",
            "uncertainties"
          ],
          "properties": {
            "checked": {
              "type": "boolean"
            },
            "result": {
              "type": "string",
              "enum": [
                "comment-only",
                "comment-and-explanation-note",
                "explanation-note-only",
                "fail",
                "uncertain",
                "not-run"
              ]
            },
            "diff_scope": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Files, directories, or working-tree scopes whose diff was inspected for comment-only behavior."
            },
            "behavior_change_assertion": {
              "type": "boolean",
              "description": "The run's explicit assertion about behavior change; strict learning-comments receipts require false."
            },
            "changed_files_reviewed": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "comment_only_paths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Changed source files verified to contain only comment or comment-adjacent whitespace edits."
            },
            "explanation_note_paths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Non-source explanation-note artifacts produced instead of noisy inline comments."
            },
            "non_comment_paths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Changed paths that are not comment-only source edits, such as explanation notes."
            },
            "non_comment_path_explanations": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_comment_path_explanation"
              }
            },
            "source_files_changed": {
              "type": "boolean"
            },
            "no_source_edit_reason": {
              "type": ["string", "null"],
              "description": "Required by strict validation when a learning-comments run produced an explanation note without changing files."
            },
            "evidence_commands": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Commands, also present in evidence.commands, used to inspect the comment-only diff."
            },
            "uncertainties": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Unresolved uncertainty that prevents strict comment-only proof when non-empty."
            }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "next_actions"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_approval_required": {
          "type": "boolean",
          "default": true
        }
      }
    }
  },
  "$defs": {
    "review_outcome_metrics": {
      "type": "object",
      "description": "Optional review outcome metrics captured from actual findings and dispositions. These fields are calibration evidence, not productivity proof; interpret beside severity, false-positive notes, duplicate rate, human decisions, review time, and validation quality.",
      "additionalProperties": true,
      "properties": {
        "findings_total": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of emitted findings in this receipt."
        },
        "findings_open": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of findings still open at receipt time."
        },
        "findings_accepted": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of findings accepted by the synthesis or human reviewer."
        },
        "findings_rejected": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of findings rejected as unsupported, speculative, or otherwise not actionable."
        },
        "findings_fixed": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of findings fixed during the run."
        },
        "findings_deferred": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of findings deferred for later human or task-packet decision."
        },
        "findings_duplicate": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of findings merged or marked duplicate."
        },
        "findings_false_positive": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of findings rejected or labeled as false positives."
        },
        "false_positive_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Ratio from 0 to 1, usually findings_false_positive divided by findings_total when both are known."
        },
        "duplicate_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Ratio from 0 to 1, usually findings_duplicate divided by findings_total when both are known."
        },
        "review_yield_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of useful findings, typically accepted plus fixed findings when those dispositions are known."
        },
        "review_yield_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Ratio from 0 to 1, usually review_yield_count divided by findings_total when both are known."
        },
        "human_decision_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of findings or actions that required explicit human acceptance, rejection, deferral, or approval."
        },
        "notes": {
          "type": "string",
          "description": "Optional caveats, unknowns, denominator notes, or interpretation limits for the review outcome metrics."
        }
      }
    },
    "effort_metrics": {
      "type": "object",
      "description": "Optional effort metrics captured from actual command timing, known model/token/cost data, and observed human review burden. Unknown values should be omitted or described in notes, not guessed.",
      "additionalProperties": true,
      "properties": {
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Total run duration in milliseconds when known."
        },
        "first_finding_latency_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Elapsed milliseconds from run start to first emitted finding when known."
        },
        "time_to_green_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Elapsed milliseconds from first failing check or task start to passing validation when known."
        },
        "commands_run_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of local commands run for this receipt."
        },
        "model_input_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Known model input token count for the run."
        },
        "model_output_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Known model output token count for the run."
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0,
          "description": "Known or provider-reported estimated cost in US dollars."
        },
        "human_review_minutes": {
          "type": "number",
          "minimum": 0,
          "description": "Observed human review burden in minutes when known."
        },
        "human_interruption_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of observed human interruptions, clarifications, or intervention turns caused by the run."
        },
        "notes": {
          "type": "string",
          "description": "Optional caveats for missing timing, token, cost, or human-burden data."
        }
      }
    },
    "command_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "result"],
      "properties": {
        "command": {
          "type": "string"
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail", "not-run", "blocked"]
        },
        "exit_code": {
          "type": ["integer", "null"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "non_comment_path_explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "reason", "behavior_safe"],
      "properties": {
        "path": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "behavior_safe": {
          "type": "boolean",
          "description": "True only when this non-comment path is explanation evidence and cannot change runtime behavior."
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "priority",
        "area",
        "title",
        "confidence",
        "evidence",
        "recommendation",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "area": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "recommendation": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["open", "accepted", "rejected", "fixed", "deferred", "duplicate"]
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "false_positive_notes": {
          "type": "string"
        }
      }
    }
  }
}
